# =============================================================================
# NixOS Flake Repository — .gitignore
# Covers: Nix/Flakes, sops-nix/age, Home Manager, disko, BTRFS, Restic,
#         Hyprland, Quickshell/QML, Neovim, editors, and OS detritus.
# =============================================================================


# -----------------------------------------------------------------------------
# Nix
# -----------------------------------------------------------------------------

# Flake evaluation artefacts (symlinks created by `nix build` / `nixos-rebuild`)
result
result-*

# nix-direnv — local .envrc eval cache; regenerated per machine
.direnv/

# Nix REPL history
.nix-repl-history

# `nix-instantiate` / `nix-build` drv caches written to cwd (rare but happens)
*.drv


# -----------------------------------------------------------------------------
# sops-nix / age — key material that must NEVER be committed
# -----------------------------------------------------------------------------

# Age identity files (private keys)
*.age
!*.age.pub           # public keys are safe to commit

# Operator age key (commonly generated to one of these paths)
keys.txt
key.txt
age-key.txt

# Any accidentally exported plain-text secrets
*.secret
*.secrets


# -----------------------------------------------------------------------------
# SSH host keys (used as age key derivation source; private side stays off-repo)
# -----------------------------------------------------------------------------
ssh_host_*_key
!ssh_host_*_key.pub


# -----------------------------------------------------------------------------
# Hardware-configuration stubs generated by nixos-generate-config
# (Committed once per host after manual curation — exclude the raw dumps)
# -----------------------------------------------------------------------------
hardware-configuration.nix.bak


# -----------------------------------------------------------------------------
# Home Manager
# -----------------------------------------------------------------------------

# Standalone Home Manager activation GC-root
home-manager-*-path


# -----------------------------------------------------------------------------
# Restic backup
# -----------------------------------------------------------------------------

# Restic repository password file if stored in tree
restic-password
restic-password.txt
.restic-password

# Restic cache (large, local only)
.cache/restic/


# -----------------------------------------------------------------------------
# Hyprland / Wayland runtime artefacts (should not be in source tree, but guard)
# -----------------------------------------------------------------------------
hyprland.conf.bak
*.hypr.bak


# -----------------------------------------------------------------------------
# Quickshell / QML
# -----------------------------------------------------------------------------

# QML module cache written alongside source files by some Qt tooling
*.qmlc
*.jsc

# Qt Creator project files if anyone opens the QML tree in an IDE
*.pro.user
*.pro.user.*
CMakeLists.txt.user


# -----------------------------------------------------------------------------
# Neovim
# -----------------------------------------------------------------------------

# Lazy.nvim / Packer lock & data (generated; not portable across machines)
lazy-lock.json
.neovim/


# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------

# VS Code / Codium
.vscode/
*.code-workspace

# JetBrains (CLion, IDEA, etc.)
.idea/
*.iml

# Vim / Neovim swap, backup, undo files
*.swp
*.swo
*~
*.orig
.*.un~
Session.vim
Sessionx.vim

# Emacs
\#*\#
.\#*
*.elc
auto-save-list
tramp

# Helix
.helix/


# -----------------------------------------------------------------------------
# OS detritus
# -----------------------------------------------------------------------------

# macOS (in case any contributor is on Darwin)
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux thumbnails
.Thumbnails/
Thumbs.db

# NFS / CIFS stale locks
.nfs*


# -----------------------------------------------------------------------------
# Temporary / local-only files
# -----------------------------------------------------------------------------

# Scratch notes that aren't meant for review
scratch.*
TODO.local
NOTES.local

# Local override flake (e.g. `flake.nix.local` for per-machine dev tweaks)
flake.nix.local
flake.local.nix

# Any local .env files (should not exist in a Nix repo, but belt-and-suspenders)
.env
.env.*
!.env.example
